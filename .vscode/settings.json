{
    "git.ignoreLimitWarning": true,
    "latex-workshop.latex.rootFile.useSubFile": false,
    "latex-workshop.latex.autoBuild.run": "onSave",
    "latex-workshop.latex.autoBuild.cleanAndRetry.enabled": true,
    "latex-workshop.formatting.latex": "latexindent",
    "latex-workshop.latexindent.path": "/Users/roxetasss/Desktop/facultad/tfg/.vscode/latexindent-wrapper",
    "latex-workshop.view.pdf.viewer": "legacy",
    "latex-workshop.latex.outDir": "%DIR%",
    "latex-workshop.view.pdf.external.viewer.command": "open",
    "latex-workshop.view.pdf.external.viewer.args": [
        "%PDF%"
    ],
    "latex-workshop.latex.tools": [
        {
            "name": "latexmk",
            "command": "/Library/TeX/texbin/latexmk",
            "args": [
                "-pdf",
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "%DOC%"
            ]
        }
    ],
    "latex-workshop.latex.recipes": [
        {
            "name": "latexmk",
            "tools": [
                "latexmk"
            ]
        }
    ],
    "cursor.general.fontSmoothingAntialiased": true,
    "cursor.general.emailPrivacyEnabled": true,
    "cursor.general.reduceTransparency": false,
    "editor.inlineSuggest.showToolbar": "onHover",
    "workbench.colorTheme": "Gruvbox Dark Soft",
    "workbench.preferredDarkColorTheme": "Cursor Light",
    "workbench.editor.decorations.colors": false,
    "workbench.editor.centeredLayoutFixedWidth": false,
    "workbench.editor.titleScrollbarSizing": "default",
    "workbench.sideBar.location": "left"
}
